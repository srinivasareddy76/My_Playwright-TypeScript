{
  "name": "my_playwright-typescript",
  "version": "1.0.0",
  "description": "Playwright TypeScript automation framework for FRBSF website testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:frbsf": "playwright test --project=frbsf-chromium",
    "test:frbsf:all": "playwright test --project=frbsf-*",
    "test:frbsf:mobile": "playwright test --project=frbsf-mobile-*",
    "test:frbsf:desktop": "playwright test --project=frbsf-chromium --project=frbsf-firefox --project=frbsf-webkit",
    "test:all": "playwright test --project=frbsf-chromium",
    "test:cross-browser": "playwright test --project=cross-browser-*",
    "test:chromium": "playwright test --project=*-chromium",
    "test:firefox": "playwright test --project=*-firefox",
    "test:webkit": "playwright test --project=*-webkit",
    "test:mobile": "playwright test --project=*-mobile-*",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "build": "tsc",
    "clean": "rm -rf dist reports test-results screenshots videos",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e",
    "frbsf",
    "web-testing"
  ],
  "author": "Test Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
